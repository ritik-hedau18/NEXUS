# =============================================================================
# NEXUS Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then set these in your IDE run config or export in your shell.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_USERNAME=postgres
DB_PASSWORD=

# --- AI Model Keys ---
GROQ_API_KEY=
JINA_API_KEY=

# --- Vector Store (Qdrant) ---
QDRANT_HOST=localhost

# --- Security (JWT) ---
# 256-bit hex-encoded secret for signing JWT tokens
JWT_SECRET=